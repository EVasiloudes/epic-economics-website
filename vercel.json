{
  "functions": {
    "api/contact.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/videos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "video/mp4"
        },
        {
          "key": "Accept-Ranges",
          "value": "bytes"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        },
        {
          "key": "Content-Encoding",
          "value": "identity"
        }
      ]
    },
    {
      "source": "/videos/(.*).webm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/webm"
        }
      ]
    },
    {
      "source": "/videos/(.*).mov",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/quicktime"
        }
      ]
    }
  ]

}