  "version": "0.0.0",
  "type": "module",
  "title": "Epic Economics",
  "description": "What would you protest about today? A play by Dimis Michaelides",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "build": "vite build && npm run prerender",
