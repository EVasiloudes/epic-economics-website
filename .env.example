# Epic Economics Website - Environment Variables
# Copy this file to .env and fill in your actual values

# =================================================================
# reCAPTCHA Configuration (Optional)
# =================================================================
# Get your reCAPTCHA v3 Site Key from: https://www.google.com/recaptcha/admin
# If not provided, the contact form will work without CAPTCHA protection
REACT_APP_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key_here

# =================================================================
# Backend API Configuration (for Vercel deployment)
# =================================================================
# Get your Resend API key from: https://resend.com/api-keys
# Required for sending contact form emails
RESEND_API_KEY=your_resend_api_key_here

# reCAPTCHA Secret Key (server-side validation)
# Get this from the same reCAPTCHA admin panel as the site key
RECAPTCHA_SECRET_KEY=your_recaptcha_v3_secret_key_here

# =================================================================
# Vercel Blob Storage (for video hosting)
# =================================================================
# Get your token from: Vercel Dashboard > Storage > Create Database > Blob
# Used for hosting video files on Vercel Blob
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# =================================================================
# Development Notes
# =================================================================
# - The REACT_APP_ prefix is required for React environment variables
# - Server-side variables (RESEND_API_KEY, RECAPTCHA_SECRET_KEY) are used in /api/contact.js
# - If reCAPTCHA keys are not provided, the form will work without CAPTCHA protection
# - If RESEND_API_KEY is not provided, email sending will be skipped (with warning logs)